# Release signing config. Copy this file to `keystore.properties` (which is
# gitignored) and fill in the real values. The release build phase reads it
# via `app/build.gradle.kts`.
#
# `storeFile` is resolved relative to the Android project root (the dir
# this file sits in). Keep your actual .jks file OUTSIDE the repo or in a
# gitignored subdirectory (`keystores/` is gitignored by convention here).

storeFile=keystores/sudoku-release.jks
storePassword=REPLACE_ME
keyAlias=sudoku
keyPassword=REPLACE_ME
